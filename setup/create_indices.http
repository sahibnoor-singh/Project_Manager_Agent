PUT projects
{
  "mappings": {
    "properties": {
      "project_id": { "type": "keyword" },
      "name": { "type": "text" },
      "status": { "type": "keyword" },
      "deadline": { "type": "date" },
      "priority": { "type": "keyword" },
      "progress": { "type": "integer" }
    }
  }
}

PUT tasks
{
  "mappings": {
    "properties": {
      "task_id": { "type": "keyword" },
